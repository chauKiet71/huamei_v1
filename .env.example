# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Server
PORT=4173
ADMIN_KEY=your-admin-key

# SePay — Webhook tự động xác nhận chuyển khoản
# Tạo webhook tại https://my.sepay.vn → Webhooks → Thêm webhook
# URL: https://your-domain.com/api/webhooks/sepay
# Xác thực: API Key (điền cùng giá trị SEPAY_WEBHOOK_API_KEY bên dưới)
SEPAY_WEBHOOK_API_KEY=your-sepay-webhook-api-key

# Tài khoản ngân hàng nhận tiền (liên kết với SePay)
SEPAY_BANK_NAME=Vietcombank
SEPAY_BANK_CODE=Vietcombank
SEPAY_BANK_ACCOUNT=1234567890
SEPAY_BANK_ACCOUNT_NAME=HUAMEI EDUCATION

# Tiền tố mã thanh toán — cấu hình cùng giá trị trong SePay (Bộ lọc mã thanh toán)
SEPAY_PAYMENT_PREFIX=HUAMEI
